# bbv2 configuration
BBV2_DB_PATH=data/bbv2.db
BBV2_LOG_DIR=data/logs
BBV2_HTTP_TIMEOUT=20

# Consumer API (0003): bearer tokens are minted via `bbv2 token create`.
# BBV2_API_HOST=127.0.0.1
# BBV2_API_PORT=8080

# Later phases:
# BRAVESEARCH_API_KEY=     # agent source discovery (0004)
# ANTHROPIC_API_KEY=       # LLM summaries / briefs
# MAILGUN_API_KEY=         # per-user email notifications
