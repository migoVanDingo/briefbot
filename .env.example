# bbv2 configuration
BBV2_DB_PATH=data/bbv2.db
BBV2_LOG_DIR=data/logs
BBV2_HTTP_TIMEOUT=20

# Consumer API (0003): bearer tokens are minted via `bbv2 token create`.
# BBV2_API_HOST=127.0.0.1
# BBV2_API_PORT=8080

# Source discovery (0004)
# BRAVESEARCH_API_KEY=

# Per-user email (0005) — all three required to send real email (else dry-run/log)
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_FROM=

# Later phases:
# ANTHROPIC_API_KEY=       # LLM summaries / briefs
