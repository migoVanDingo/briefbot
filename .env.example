# bbv2 configuration
BBV2_DB_PATH=data/bbv2.db
BBV2_LOG_DIR=data/logs
BBV2_HTTP_TIMEOUT=20

# Deploy / network (set for the Tailscale family deploy — see roadmap)
# ALLOWED_ORIGINS=http://localhost:5180,http://<tailscale-host>:5180  # CORS allowlist (csv)
# BBV2_SERVE_HOST=127.0.0.1           # `bbv2 serve` bind host (set to the tailnet iface)
# BBV2_ALLOW_PRIVATE_FETCH=false      # true only for local dev; disables the SSRF IP guard

# Consumer API (0003): bearer tokens are minted via `bbv2 token create`.
# BBV2_API_HOST=127.0.0.1
# BBV2_API_PORT=8080

# Source discovery (0004)
# BRAVESEARCH_API_KEY=

# Per-user email (0005). Real send needs SENDING key + domain + a from-address
# (else falls back to dry-run/log). Auth uses the SENDING key.
# MAILGUN_SENDING_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_FROM=               # or EMAIL_FROM
# MAILGUN_API_KEY=            # account key (fallback only; sending key preferred)

# Dashboard auth (0006) — backend verifies Firebase ID tokens via firebase-admin
# FIREBASE_CONFIG=         # path to the Firebase service-account JSON
#   (frontend Firebase web config lives in dashboard/.env as VITE_FIREBASE_*)

# Backend sessions (0019) — the Firebase token is exchanged once at
# /api/auth/exchange for bbv2's own access JWT + refresh token (HttpOnly cookies).
# BBV2_JWT_SECRET=            # REQUIRED in prod (random 48+ chars). Unset → ephemeral
#                             # per-process secret (sessions drop on restart; serve warns).
# BBV2_ACCESS_TTL_S=900       # access-JWT lifetime (15 min)
# BBV2_REFRESH_TTL_S=2592000  # refresh/session lifetime (30 days)
# BBV2_COOKIE_SECURE=false    # true for the HTTPS (Tailscale) deploy
# BBV2_COOKIE_SAMESITE=strict # strict|lax|none (dashboard + API are same-site)
# BBV2_COOKIE_ACCESS=bbv2_access
# BBV2_COOKIE_REFRESH=bbv2_refresh

# LLM — Haiku for prose (briefs / rundowns / chat / moderation)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # default is Haiku; override if needed

# Cheap model for story relevance classification (0014) — xAI Grok, OpenAI-compatible.
# Falls back to Haiku if unset/erroring. Set GROK_API_KEY to activate.
# GROK_API_KEY=
# GROK_MODEL=grok-3-mini                       # set a current id if the default retires
# RELEVANCE_PROVIDER=grok                       # 'grok' (default when key set) | 'anthropic'

# Per-topic header images (0024) — Grok Imagine, reuses GROK_API_KEY.
# TOPIC_IMAGES_ENABLED=true                     # needs a Grok key; false to disable
# GROK_IMAGE_MODEL=grok-imagine-image-quality   # set a current id per your xAI account
# BBV2_TOPIC_IMAGES_DIR=data/topic_images       # where generated images are stored

# Profile avatars (0028) — identicon by default; optional Grok-generated image.
# AVATARS_ENABLED=true                          # needs a Grok key; false = identicon only
# BBV2_AVATARS_DIR=data/avatars                 # where generated avatars are stored
# GROK_IMAGE_PRICE=0.02                          # est. USD per generated image (metrics)

# Logging (0026)
# BBV2_LOG_LEVEL=INFO                            # ERROR | WARNING | INFO | DEBUG (-v = DEBUG)
# BBV2_LOG_FORMAT=text                           # text (default) | json
# BBV2_LOG_DIR=data/logs                         # rotating bbv2.log lives here

# Topic embedding index + on-demand source discovery (0030). OpenAI embeddings
# power the topic vector index and evidence-based source routing; without a key,
# the agent's find_sources still works but routing falls back to a heuristic name.
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_EMBED_PRICE=0.02                         # est. USD / 1M tokens (cost metrics)
# EMBED_CENTROID_DAYS=30                          # a topic vector = centroid of recent briefs
# BBV2_PLACEMENT_MIN=0.32                         # min cosine to place in an existing topic
# BBV2_PLACEMENT_MULTI=0.45                       # cosine to ALSO attach to a 2nd topic
# BBV2_DISCOVERY_PREVIEW_MAX=6                    # candidate feeds surfaced in a search preview

# Per-user daily token budget (0012/0014). Counts the user's agent work + their
# own provisioning; background/shared work goes to a system bucket (not charged).
# TOKEN_LIMIT=100000
# TOKEN_WINDOW_S=86400
# TOKEN_LIMIT_ENABLED=true

# Scheduling cadence defaults (0014) — per-topic overrides set in Admin → Scheduling
# (0020). DISCOVER/COLLECT are the fallback when a topic has no override; MAX_* are
# the fallback caps (overridable per topic). SCHEDULER_WINDOW_MIN MUST match the
# `bbv2 tick` crontab interval (0020 sets it to */15) — it's the daily-slot window.
# DISCOVER_INTERVAL_MIN_DEFAULT=10080          # weekly
# COLLECT_INTERVAL_MIN_DEFAULT=360             # 6h
# SCHEDULER_WINDOW_MIN=15                       # tick heartbeat / daily-slot window
#
# Estimated LLM cost (0021) — USD per 1M tokens, for the metrics ballpark (no live
# billing API). Override as prices change.
# GROK_PRICE_IN=0.30
# GROK_PRICE_OUT=0.50
# HAIKU_PRICE_IN=1.00
# HAIKU_PRICE_OUT=5.00
# DASHBOARD_URL=http://localhost:5180          # used in the nightly 'brief ready' email
# ONBOARD_BRIEF_WINDOW_MIN=1440                # build a brief for topics added in the
#                                              # account's first N min (initial setup)
# MAX_SOURCES_PER_TOPIC=5                       # cap candidate sources per topic
# MAX_STORIES_PER_SOURCE=7                      # cap stories ingested per source per collect

# Auto-drop dead/blocked feeds (0029): disable a source after N consecutive
# droppable-4xx fetch failures (401/403/404; 410 drops immediately). A successful
# fetch resets the streak. Set to 0 to turn auto-dropping off.
# BBV2_SOURCE_DROP_THRESHOLD=3

# Roles (0009) — OWNER-ONLY admin. The ONLY way to grant admin: list emails here
# and restart. No API/UI/CLI promotes users. Usually just your own email.
# ADMIN_EMAILS=you@example.com

# Topic guardrails + rate limits (0009)
# MODERATION_FAIL_OPEN=false        # on LLM moderation error: false = deny (safe)
# RL_TOPIC_CREATE_PER_HOUR=5        # per-user topic creations / hour
# RL_PROVISION_PER_HOUR=10          # per-user topic provisions / hour
